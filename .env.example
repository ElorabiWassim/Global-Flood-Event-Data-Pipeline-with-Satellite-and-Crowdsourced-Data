# =============================================================================
# Global Flood Event Data Pipeline - Environment Configuration TEMPLATE
# =============================================================================
# Copy this file to `.env` and fill in real values. Never commit `.env`.
#
#   cp .env.example .env        # macOS / Linux
#   Copy-Item .env.example .env # Windows PowerShell
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL + PostGIS)
# -----------------------------------------------------------------------------
# Prefer DATABASE_URL when set; otherwise the POSTGRES_* parts below are used
# to assemble a SQLAlchemy connection string in config/settings.py.
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg2://postgres:changeme@localhost:5432/postgres

# -----------------------------------------------------------------------------
# FastAPI service
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000

# -----------------------------------------------------------------------------
# Pipeline tunables
# -----------------------------------------------------------------------------
H3_RESOLUTION=7
HTTP_TIMEOUT=60
RELIEFWEB_APPNAME=ai-students-flood-project

# -----------------------------------------------------------------------------
# Airflow
# -----------------------------------------------------------------------------
AIRFLOW_UID=50000

# -----------------------------------------------------------------------------
# Optional ingestion overrides
# -----------------------------------------------------------------------------
# EM-DAT: provide a signed download URL if you have one, otherwise the
# pipeline falls back to the seed CSV under data/raw/emdat/.
# EMDAT_DOWNLOAD_URL=

# Copernicus EMS feed override (optional; defaults to the bundled CSV).
# COPERNICUS_EMS_FEED_URL=

# Copernicus CDS API credentials (only needed for the future GloFAS branch).
# CDS_API_URL=https://cds.climate.copernicus.eu/api/v2
# CDS_API_KEY=

# -----------------------------------------------------------------------------
# Social-media ingestion (Bluesky)
# -----------------------------------------------------------------------------
ENABLE_SOCIAL_MEDIA_INGESTION=true
BLUESKY_MAX_POSTS=100
BLUESKY_PER_QUERY_LIMIT=25
BLUESKY_LOOKBACK_HOURS=24

# Optional Bluesky App Password credentials. When set, the ingester uses the
# authenticated `bsky.social` PDS endpoint instead of the public AppView.
# Create one at https://bsky.app/settings/app-passwords
# BLUESKY_HANDLE=@your-handle.bsky.social
# BLUESKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
